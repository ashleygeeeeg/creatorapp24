# maligeeAi frontend — copy to .env.local for local dev

# API origin (no trailing slash, no /api path)
REACT_APP_BACKEND_URL=http://localhost:8000

# Public site URL (used for AppCreator24 / share links)
REACT_APP_PUBLIC_WEB_URL=http://localhost:3000

# Your published AppCreator24 Android app (WebView shell)
# Example: https://www.appcreator24.com/app2428269-xxxxx
REACT_APP_APPCREATOR24_APP_URL=

# AppCreator24 builder / marketing (optional)
REACT_APP_APPCREATOR24_BUILDER_URL=https://www.appcreator24.com
